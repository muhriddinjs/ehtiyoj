# Environment Variables — EXTIYOJ PWA
# Bu faylni .env.local deb saqlang va hech qachon git ga push qilmang!

# ============ SUPABASE ============
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your_anon_key
SUPABASE_SERVICE_ROLE_KEY=eyJ...your_service_role_key

# ============ TELEGRAM BOT ============
# @BotFather dan olingan token
TELEGRAM_BOT_TOKEN=7XXXXXXXXX:AAF_xxxxxxxxxxxxxxxxxxxxx
# Botning username i (@ siz)
TELEGRAM_BOT_USERNAME=extiyoj_bot

# ============ YANDEX MAPS ============
# developer.tech.yandex.ru dan olingan kalit
NEXT_PUBLIC_YANDEX_MAPS_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ============ JWT ============
# Kamida 32 ta tasodifiy belgi — openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-long

# ============ APP ============
NEXT_PUBLIC_APP_URL=http://localhost:3000
